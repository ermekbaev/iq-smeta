# --- База данных (локально через docker-compose) ---
# порт 5433: 5432 может быть занят системным PostgreSQL
DATABASE_URL="postgresql://iqsmeta:iqsmeta@localhost:5433/iqsmeta?schema=public"

# --- NextAuth ---
# сгенерировать: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"

# --- Провайдеры ИИ (PLAN 3.1) ---
# mock — заглушки для разработки; prod — реальные сервисы
AI_PROVIDER="mock"

# В режиме prod собираются по-сервисно:
ASR_PROVIDER="yandex"        # речь→текст: yandex (SpeechKit) | gemini
LLM_PROVIDER="yandex"        # позиции + эмбеддинги: yandex | gigachat | gemini

# Google Gemini — бесплатный tier для dev-тестов (ключ: aistudio.google.com).
# Эмбеддинги text-embedding-004 = 768. Для Gemini нужна отдельная миграция vector(768).
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# Яндекс Cloud (SpeechKit / YandexGPT)
YANDEX_API_KEY=""
YANDEX_FOLDER_ID=""
# YANDEX_GPT_MODEL="yandexgpt"   # необязательно
# Эмбеддинги YandexGPT — 256-мерные, текущая схема БД: vector(256).

# GigaChat (Сбер) — эмбеддинги 1024. Для GigaChat нужна отдельная миграция vector(1024).
GIGACHAT_AUTH_KEY=""
# GIGACHAT_SCOPE="GIGACHAT_API_PERS"   # PERS/CORP в зависимости от тарифа
# GIGACHAT_MODEL="GigaChat"
# TLS Сбербанка: указать путь к Russian Trusted CA (нативно для Node):
# NODE_EXTRA_CA_CERTS="/path/to/russian_trusted_root_ca.pem"

# --- Тюнинг подбора по базе (PLAN 3.2), необязательно ---
# Порог автоподбора: выше порога — берём молча, ниже — спрашиваем подтверждение.
# MATCH_THRESHOLD="0.6"
# Веса семантики/нечёткого сравнения (с реальными эмбеддингами семантика сильнее).
# MATCH_W_SEMANTIC="0.7"
# MATCH_W_FUZZY="0.3"

# --- Фирменное оформление PDF (PLAN 3.5 / 7) ---
COMPANY_NAME="IQ SMETA"
COMPANY_CONTACTS="тел. — · email — · ИНН —"
# логотип: публичный URL или data:URI (data:image/png;base64,...)
COMPANY_LOGO_URL=""
