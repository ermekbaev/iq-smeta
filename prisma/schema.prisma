// IQ SMETA — схема БД (см. PLAN.md, раздел 4)
//
// ВАЖНО: размерность вектора price_item.embedding зафиксирована под
// embeddings-провайдера (см. PLAN 3.1 / раздел 2). Текущее значение — 768
// (dev: Gemini text-embedding-004). Прод-вариант — 1024 (GigaChat).
// При смене провайдера менять И здесь, И EMBEDDING_DIM в src/lib/ai/types.ts,
// затем новая миграция (guard в src/lib/ai/index.ts сверяет значения).
// Тип vector не поддерживается Prisma нативно — используем Unsupported,
// а читаем/пишем вектор через raw SQL (см. src/lib/match).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Role {
  ADMIN
}

enum Category {
  MATERIALS // Материалы
  WORKS // Работы
  EQUIPMENT // Оборудование
  DELIVERY // Доставка
  OVERHEAD // Издержки
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         Role       @default(ADMIN)
  createdAt    DateTime   @default(now()) @map("created_at")
  estimates    Estimate[]

  @@map("users")
}

model PriceItem {
  id        String   @id @default(cuid())
  name      String
  unit      String
  price     Decimal  @db.Decimal(12, 2)
  category  Category
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // vector(768) — управляется raw SQL, см. комментарий вверху файла
  embedding Unsupported("vector(768)")?

  aliases       Alias[]
  estimateItems EstimateItem[]

  // повторная загрузка прайса обновляет существующую позицию (upsert), а не дублирует
  @@unique([name, unit])
  @@index([category])
  @@map("price_items")
}

model Alias {
  id          String    @id @default(cuid())
  // нормализованный текст из речи; уникален — "последняя правка побеждает" (PLAN 3.3)
  spokenText  String    @unique @map("spoken_text")
  priceItemId String    @map("price_item_id")
  priceItem   PriceItem @relation(fields: [priceItemId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("aliases")
}

model Estimate {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  clientName String?        @map("client_name")
  total      Decimal        @default(0) @db.Decimal(14, 2)
  createdAt  DateTime       @default(now()) @map("created_at")
  items      EstimateItem[]

  @@index([userId])
  @@map("estimates")
}

model EstimateItem {
  id          String     @id @default(cuid())
  estimateId  String     @map("estimate_id")
  estimate    Estimate   @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  // подобранная позиция прайса; null — если позиция не нашлась и заведена вручную
  priceItemId String?    @map("price_item_id")
  priceItem   PriceItem? @relation(fields: [priceItemId], references: [id], onDelete: SetNull)
  name        String
  qty         Decimal    @db.Decimal(12, 3)
  unit        String
  price       Decimal    @db.Decimal(12, 2)
  sum         Decimal    @db.Decimal(14, 2)
  // категория хранится в позиции: группировка PDF не зависит от связанного прайса
  category    Category   @default(OVERHEAD)

  @@index([estimateId])
  @@map("estimate_items")
}
